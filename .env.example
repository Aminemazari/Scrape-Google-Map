# Google Maps Scraper Configuration
# Copy this file to `.env` and update values as needed

# Server Configuration
PORT=3000

# API Authentication
# Generate a strong API key for security
# Example: openssl rand -hex 32
API_KEY=your-secret-api-key-change-me

# Playwright Browser (optional)
# Set to 'true' to run in headless mode (no visible window)
# HEADLESS=false

# Debug Logging (optional)
# Set to 'true' for verbose logging
# DEBUG=false
